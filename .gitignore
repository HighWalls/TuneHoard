# Secrets and auth caches
.env
.spotify_cache
.cache

# Server-side user state — paths, optional Spotify creds
.tunehoard_settings.json
.tunehoard_settings.json.tmp

# Dashboard upload area (user-supplied MP3s for failed tracks)
dashboard/tunehoard/uploads/

# Claude Design export bundles (we keep the unzipped HTML, not the zip)
dashboard/*.zip

# Claude Code session state (contains local paths, username)
.claude/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Runtime output
downloads/
*.csv
*.mp3
failures.txt

# PyInstaller artifacts
build/
dist/
*.spec.bak

# Bundled ffmpeg (fetched by CI; gitignored so we don't commit a ~80 MB binary)
bin/

